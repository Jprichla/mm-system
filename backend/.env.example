# Banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mm_system?schema=public"

# Segurança JWT
JWT_SECRET="troque_esta_chave_por_uma_chave_segura"
JWT_EXPIRES_IN="15m"

# Servidor
PORT=4000
NODE_ENV="development"

# Cloudflare R2 (storage de arquivos: fotos, PDFs, DWG etc.)
R2_ACCOUNT_ID="seu_account_id_cloudflare"
R2_ACCESS_KEY_ID="sua_access_key_id"
R2_SECRET_ACCESS_KEY="sua_secret_access_key"
R2_BUCKET_NAME="mm-system-attachments"
# Custom Domain configurado no bucket, OU o dev URL (Settings > Public access > r2.dev) do bucket
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"
